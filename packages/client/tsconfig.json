{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@mahjong/shared": [
        "../shared/src/index.ts"
      ],
      "@mahjong/shared/*": [
        "../shared/src/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ]
}